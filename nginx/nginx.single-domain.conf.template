# ${SHORT_DOMAIN} — serves the React SPA, proxies API calls, and resolves short links at /:code
server {
    listen 80;
    server_name ${SHORT_DOMAIN};

    # Real-IP: trust upstream proxies on Docker-internal and LAN ranges so that
    # $remote_addr reflects the actual client IP rather than the proxy's IP.
    # Covers cloudflared (Docker bridge) and nginx-proxy-manager (LAN or Docker).
    set_real_ip_from  10.0.0.0/8;
    set_real_ip_from  172.16.0.0/12;
    set_real_ip_from  192.168.0.0/16;
    real_ip_header    X-Forwarded-For;
    real_ip_recursive on;

    root /usr/share/nginx/html;
    index index.html;

    location /api/ {
        resolver           127.0.0.11 valid=10s;
        set $backend       http://backend:3000;
        proxy_pass         $backend;
        proxy_http_version 1.1;
        proxy_set_header   Host              $host;
        proxy_set_header   X-Real-IP         $remote_addr;
        proxy_set_header   X-Forwarded-For   $proxy_add_x_forwarded_for;
        proxy_set_header   X-Forwarded-Proto $scheme;
    }

    # Extensionless single-segment paths resolve through the backend so it can
    # return the right short-link status page: valid, invalid, missing, expired.
    location ~ "^/[^/.]+$" {
        resolver           127.0.0.11 valid=10s;
        set $backend       http://backend:3000;
        proxy_pass         $backend;
        proxy_http_version 1.1;
        proxy_set_header   Host              $host;
        proxy_set_header   X-Real-IP         $remote_addr;
        proxy_set_header   X-Forwarded-For   $proxy_add_x_forwarded_for;
        proxy_set_header   X-Forwarded-Proto $scheme;
    }

    # SPA fallback — all non-API, non-short-code, non-file routes serve index.html
    location / {
        try_files $uri /index.html;
    }
}
