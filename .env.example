# PostgreSQL (required)
POSTGRES_DB=shorturl
POSTGRES_PASSWORD=changeme

# Domains. SHORT_DOMAIN hosts the SPA. If S_DOMAIN is set, it hosts short-link
# resolution. Leave S_DOMAIN blank to serve short links as SHORT_DOMAIN/<id>.
SHORT_DOMAIN=short.url
S_DOMAIN=s.url

# Scheme for short links shown to users (http or https).
S_SCHEME=http

# Minutes a browser-scoped client must wait before the same long URL can generate a unique new code.
SHORTEN_COOLDOWN_MINUTES=60

# Stable HMAC secrets for anonymized client/IP identity (required).
# Generate two different values, for example: openssl rand -hex 32
IP_HASH_SECRET=change-me-generate-a-long-random-secret
CLIENT_ID_HASH_SECRET=change-me-generate-a-different-long-random-secret

# Anonymous browser-scoped identity cookie used for duplicate detection.
CLIENT_COOKIE_NAME=lw_client_id
CLIENT_COOKIE_MAX_AGE_DAYS=365

# Maximum short link lifetime in months (default: 12). Links with no custom expiry are capped here.
MAX_LINK_EXPIRY_MONTHS=12
