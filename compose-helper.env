# compose-helper configuration
# Rename to compose-helper.env (matching your script's filename) and place it
# alongside the script. Values here override environment variables inherited
# from the calling shell.

# Override the docker compose project name. Defaults to the directory name.
# Useful when the directory name does not match the intended project name.
DCH_PROJECT_NAME=url-shortener

# Seconds to wait for containers to stop gracefully before killing them.
# Applies to: stop, down, restart
DCH_STOP_TIMEOUT=30

# Number of log lines to show before following live output.
# Applies to: up, logs
DCH_LOGS_TAIL=10
